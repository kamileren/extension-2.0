{
  "manifest_version": 3,
  "name": "Arb Betting Calculator",
  "version": "1.0",
  "description": "Automatically calculates arbitrage opportunities between DraftKings and FanDuel",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://*.draftkings.com/*",
    "https://*.fanduel.com/*",
    "https://*.fanduel.ca/*",
    "https://*.betrivers.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.draftkings.com/*"],
      "js": ["content_dk.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.fanduel.com/*", "https://*.fanduel.ca/*"],
      "js": ["content_fd.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.betrivers.com/*"],
      "js": ["content_br.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arb Calculator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
